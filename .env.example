# Neon Postgres (Vercel Marketplace).
# Si conectas Neon desde Vercel, esta variable se inyecta sola.
# Para desarrollo local: vercel env pull .env.local
DATABASE_URL=

# Cloudflare Turnstile (verificación antirrobots para nuevos reportes).
# Crea un widget en https://dash.cloudflare.com/?to=/:account/turnstile
# - NEXT_PUBLIC_TURNSTILE_SITE_KEY: clave pública (se incrusta en el formulario).
# - TURNSTILE_SECRET_KEY: clave secreta (solo en el servidor).
# Si se dejan vacías, la verificación se omite y los reportes funcionan igual
# que antes (útil en desarrollo y en el modo demo).
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# OpenPanel analytics.
# NEXT_PUBLIC_OPENPANEL_CLIENT_ID comes from the OpenPanel project settings.
# OPENPANEL_API_URL should point to your self-hosted OpenPanel API, including /api.
# Example: https://openpanel.example.com/api
NEXT_PUBLIC_OPENPANEL_CLIENT_ID=
OPENPANEL_API_URL=
NEXT_PUBLIC_OPENPANEL_DASHBOARD_URL=
NEXT_PUBLIC_OPENPANEL_PRODUCTION_HOST=terremotovenezuela.app
